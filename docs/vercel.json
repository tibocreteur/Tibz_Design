{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "accept-language",
          "value": "(?<lang>fr.*)"
        }
      ],
      "destination": "/fr/",
      "permanent": false
    },
    {
      "source": "/",
      "destination": "/en/",
      "permanent": false
    },
    {
      "source": "/fr",
      "destination": "/fr/",
      "permanent": true
    },
    {
      "source": "/en",
      "destination": "/en/",
      "permanent": true
    }
  ]
}