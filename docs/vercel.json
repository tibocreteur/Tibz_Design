{
  "cleanUrls": true,
  "images": {
    "sizes": [320, 400, 640, 750, 800, 1080, 1200, 1920],
    "formats": ["image/avif", "image/webp"],
    "minimumCacheTTL": 3600
  },
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "accept-language",
          "value": "(?<lang>fr.*)"
        }
      ],
      "destination": "/fr/",
      "permanent": false
    },
    {
      "source": "/",
      "destination": "/en/",
      "permanent": false
    },
    {
      "source": "/fr",
      "destination": "/fr/",
      "permanent": true
    },
    {
      "source": "/en",
      "destination": "/en/",
      "permanent": true
    }
  ]
}